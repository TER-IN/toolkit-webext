{
    "manifest_version": 3,
    "name": "TERIN Toolkit",
    "description": "Internal developer productivity toolkit for TERIN",
    "icons": {
        "16": "public/icons/icon-16.png",
        "48": "public/icons/icon-48.png",
        "128": "public/icons/icon-128.png"
    },
    "action": {
        "default_title": "TERIN Toolkit"
    },
    "permissions": [
        "scripting",
        "storage",
        "activeTab",
        "tabs",
        "unlimitedStorage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "src/background/index.ts",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/index.tsx"
            ],
            "run_at": "document_idle"
        }
    ]
}